<?xml version='1.0' encoding='utf-8'?>
<widget id="uz.dilshodbek.taximeterpro" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Taksometr Pro</name>
    <description>
        Fonda va blok holatida ham aniq hisoblovchi professional taksometr ilovasi.
    </description>
    <author email="support@taximeter.uz" href="http://github.com">
        Dilshodbek
    </author>
    
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="green.png" /> </platform>

    <plugin name="cordova-plugin-geolocation" spec="^4.1.0" />
    <plugin name="cordova-plugin-background-mode" spec="^0.7.3" />
    <plugin name="cordova-background-geolocation-lt" spec="^4.12.0" />
</widget>
