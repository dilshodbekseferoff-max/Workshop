name: Build Android APK
on:
  push:
    branches: [ main, master ]
  workflow_dispatch: # Bu qator sizga qo'lda ham ishga tushirish tugmasini chiqarib beradi

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v3

    - name: set up JDK 11
      uses: actions/setup-java@v3
      with:
        java-version: '11'
        distribution: 'zulu'

    - name: Initialize Cordova
      run: |
        npm install -g cordova
        cordova create build_dir uz.dilshodbek.taximeterpro "Taksometr Pro"
        cd build_dir
        rm -rf www/*

    - name: Copy files
      run: |
        cp index.html build_dir/www/index.html || true
        cp config.xml build_dir/config.xml || true
        cp *.png build_dir/www/ || true

    - name: Build APK
      run: |
        cd build_dir
        cordova platform add android
        cordova build android --device

    - name: Upload APK artifact
      uses: actions/upload-artifact@v3
      with:
        name: Taksometr-Pro-APK
        path: build_dir/platforms/android/app/build/outputs/apk/debug/app-debug.apk
